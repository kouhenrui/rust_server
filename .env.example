# 复制为 `.env` 后按本地环境修改：
#   copy .env.example .env
#
# 已在终端 export 的环境变量优先于本文件（不会被 .env 覆盖）。

# 日志（须在 tracing 初始化前生效）
# RUST_LOG 必须写成一行，逗号分隔，例如：
#   info            → 全局默认级别
#   thumbor=info    → 本服务
#   tower_http=info → HTTP 中间件
RUST_LOG=info,thumbor=info,tower_http=info

# 服务
THUMBOR_BIND=0.0.0.0:8080
THUMBOR_MAX_SOURCE_BYTES=26214400
THUMBOR_FETCH_TIMEOUT_MS=10000
THUMBOR_ALLOW_REMOTE=true
# THUMBOR_WATERMARK_FONT=C:\Windows\Fonts\arial.ttf
# THUMBOR_LOCAL_SOURCE_ROOT=D:\images
THUMBOR_LOG_LEVEL=info

# 缓存后端（热插拔）：disabled | memory | redis
# THUMBOR_CACHE_BACKEND=disabled
# THUMBOR_CACHE_MEMORY_MAX_ENTRIES=1024
# THUMBOR_CACHE_MEMORY_TTL_SECS=3600

# Redis（THUMBOR_CACHE_BACKEND=redis 时生效）
# THUMBOR_REDIS_URL=redis://user:pass@127.0.0.1:6379/0
# THUMBOR_REDIS_HOST=127.0.0.1
# THUMBOR_REDIS_PORT=6379
# THUMBOR_REDIS_DB=0
# THUMBOR_REDIS_USERNAME=
# THUMBOR_REDIS_PASSWORD=

# 数据库（必选，热插拔）：postgres | mysql | sqlite | mongodb（未设置时默认 sqlite）
# THUMBOR_DB_BACKEND=sqlite
# THUMBOR_DB_URL=postgres://user:pass@127.0.0.1:5432/thumbor
# THUMBOR_DB_HOST=127.0.0.1
# THUMBOR_DB_PORT=5432
# THUMBOR_DB_NAME=thumbor
# THUMBOR_DB_USERNAME=
# THUMBOR_DB_PASSWORD=
# THUMBOR_DB_PATH=thumbor.db

# 自定义 .env 文件路径（可选）
# THUMBOR_DOTENV_PATH=.env.local
